Options -Indexes

# Block direct access to config files
<FilesMatch "^(database|helpers)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Route /api/products → /api/products.php
# Route /api/orders   → /api/orders.php
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/([a-z_]+)/?$ api/$1.php [QSA,L]
